{
  "name": "bookearth-frontend",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "copy-cesium": "cpx \"node_modules/cesium/Build/Cesium/**\" public/cesium",
    "dev": "npm run copy-cesium && next dev",
    "build": "npm run copy-cesium && next build",
    "start": "next start",
    "format": "prettier --write . --ignore-path ../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../.prettierignore",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "cpx2": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.5.0",
    "zod": "^4.1.11"
  },
  "dependencies": {
    "cesium": "^1.131.0",
    "next": "^16.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "engines": {
    "node": ">=24"
  }
}
